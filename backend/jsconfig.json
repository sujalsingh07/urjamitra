{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "lib": ["es6"],
    "allowJs": true,
    "strict": false
  },
  "exclude": [
    "node_modules",
    "**/*.test.js",
    "build",
    "dist",
    "routes/demoRoutes.js"
  ],
  "include": [
    "./server.js",
    "./test-server.js",
    "./controllers/*.js",
    "./models/*.js",
    "./routes/*.js",
    "./services/*.js"
  ]
}
